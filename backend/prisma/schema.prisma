// ReqTrack データモデル
// 上流(要件→タスク→見積→ガント計画)と下流(進捗報告→進捗率→遅延)を 1 スキーマで繋ぐ。
// データモデルの判断根拠は docs/adr/0002-stack-and-architecture.md / docs/design.md を参照。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// プロジェクト(案件)。1 案件 = 1 ガントチャート。
model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  // 案件区分 (US-024): new=新規 / existing=既存改修
  kind         String        @default("new")
  // 既存改修時に参照する資料プロジェクト (US-024)
  referenceProject   ReferenceProject? @relation(fields: [referenceProjectId], references: [id], onDelete: SetNull)
  referenceProjectId String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  requirements Requirement[]
  tasks        Task[]
  dailyReports DailyReport[]

  @@index([referenceProjectId])
}

/// 参照資料プロジェクト (US-024)。既存改修の設計/ソース等の資料フォルダを ReqTrack 管理下に登録し、
/// スキャンで内容を読取って見積の参照に使う。
model ReferenceProject {
  id        String          @id @default(cuid())
  name      String
  rootPath  String
  note      String?
  scannedAt DateTime?
  createdAt DateTime        @default(now())
  files     ReferenceFile[]
  projects  Project[]
}

/// スキャンで読み取った参照資料ファイル (US-024)。テキスト系は冒頭抜粋を保持。
model ReferenceFile {
  id                 String           @id @default(cuid())
  referenceProject   ReferenceProject @relation(fields: [referenceProjectId], references: [id], onDelete: Cascade)
  referenceProjectId String
  path               String // ルートからの相対パス
  size               Int
  ext                String?
  excerpt            String? // テキスト系の冒頭抜粋
  createdAt          DateTime         @default(now())

  @@index([referenceProjectId])
}

/// 顧客からヒアリング/提示された要件 (US-001)。タスク洗い出しの起点 (US-002)。
model Requirement {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  content   String
  source    String? // 例: hearing / customer-list
  createdAt DateTime @default(now())
  tasks     Task[]

  @@index([projectId])
}

/// 要員 (US-005)。タスクの担当者・進捗報告者。
model Member {
  id        String           @id @default(cuid())
  name      String
  role      String?
  email     String?          @unique
  // 単価(円/時) (US-028)。工賃概算 = 人日 × 1日の作業時間 × 単価
  hourlyRate Float?
  createdAt DateTime         @default(now())
  tasks     Task[]
  reports   ProgressReport[]
  dailyReports DailyReport[]
}

/// アプリ全体設定 (US-027)。単一行(id="singleton")で運用。
model Settings {
  id                 String   @id @default("singleton")
  hoursPerDay        Float    @default(8)
  minEstimateDays    Float    @default(0.1)
  reviewRatio        Float    @default(0.3)
  reviewMinDays      Float    @default(0.1)
  defaultUtilization Float    @default(1.0)
  updatedAt          DateTime @updatedAt
}

/// 祝日 (US-006)。スケジュール算出時の非稼働日。
model Holiday {
  id   String   @id @default(cuid())
  date DateTime @unique
  name String
}

/// 作業タスク/工程 (US-002)。見積(US-003)とガント計画(US-004)・進捗(US-008)を保持。
model Task {
  id            String           @id @default(cuid())
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  requirement   Requirement?     @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  requirementId String?
  name          String
  // WBS 階層 (US-013)。level 1=機能 / 2=対象 / 3=作業タスク
  level         Int              @default(3)
  wbsId         String?
  parent        Task?            @relation("TaskHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  parentId      String?
  children      Task[]           @relation("TaskHierarchy")
  // 工程区分 / 見積根拠 (US-013) と種別 (US-014: task|review|efficiency)
  phase         String?
  estimateNote  String?
  kind          String           @default("task")
  // レビュー形態 (US-047): sync=対面(レビュワー・レビュイー同時) / doc=書面(レビュワーのみ)
  reviewFormat  String?
  // 対面レビューの同期ペア識別子 (US-047)。同じ値のタスクは同一区間に配置する
  reviewLinkId  String?
  // 見積 (US-003)。小数点以下の自由値 (US-012、効率化調整で負値も可)
  estimateDays  Float            @default(0)
  // 稼働率 0 < r <= 1 (US-012)。期間(営業日) = ceil(工数 ÷ 稼働率)
  utilizationRate Float          @default(1.0)
  // ガント計画 (US-004)
  plannedStart  DateTime?
  plannedEnd    DateTime?
  // 進捗率 0-100 (US-008)
  progress      Int              @default(0)
  assignee      Member?          @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  reports       ProgressReport[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([parentId])
}

/// 日報 (US-017)。報告者・日付ごとの 1 提出。複数の進捗報告(明細)を束ねる。
model DailyReport {
  id         String           @id @default(cuid())
  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId  String
  member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId   String
  reportDate DateTime
  note       String?
  createdAt  DateTime         @default(now())
  entries    ProgressReport[]

  @@index([projectId])
  @@index([memberId])
}

/// 進捗報告 (US-007)。タスクの進捗率へ反映され(US-008)、遅延検出の根拠になる(US-009/010)。
/// 日報(US-017)経由の明細は dailyReportId を持つ。個別報告(US-007)は null。
model ProgressReport {
  id            String       @id @default(cuid())
  task          Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId        String
  member        Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId      String
  dailyReport   DailyReport? @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  dailyReportId String?
  progress      Int // 報告時点の進捗率 0-100
  comment       String?
  reportedAt    DateTime     @default(now())

  @@index([taskId])
  @@index([memberId])
  @@index([dailyReportId])
}
