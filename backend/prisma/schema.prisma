// ReqTrack データモデル
// 上流(要件→タスク→見積→ガント計画)と下流(進捗報告→進捗率→遅延)を 1 スキーマで繋ぐ。
// データモデルの判断根拠は docs/adr/0002-stack-and-architecture.md / docs/design.md を参照。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// プロジェクト(案件)。1 案件 = 1 ガントチャート。
model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  requirements Requirement[]
  tasks        Task[]
}

/// 顧客からヒアリング/提示された要件 (US-001)。タスク洗い出しの起点 (US-002)。
model Requirement {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  content   String
  source    String? // 例: hearing / customer-list
  createdAt DateTime @default(now())
  tasks     Task[]

  @@index([projectId])
}

/// 要員 (US-005)。タスクの担当者・進捗報告者。
model Member {
  id        String           @id @default(cuid())
  name      String
  role      String?
  email     String?          @unique
  createdAt DateTime         @default(now())
  tasks     Task[]
  reports   ProgressReport[]
}

/// 祝日 (US-006)。スケジュール算出時の非稼働日。
model Holiday {
  id   String   @id @default(cuid())
  date DateTime @unique
  name String
}

/// 作業タスク/工程 (US-002)。見積(US-003)とガント計画(US-004)・進捗(US-008)を保持。
model Task {
  id            String           @id @default(cuid())
  project       Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId     String
  requirement   Requirement?     @relation(fields: [requirementId], references: [id], onDelete: SetNull)
  requirementId String?
  name          String
  // 見積 (US-003)
  estimateDays  Float            @default(0)
  // ガント計画 (US-004)
  plannedStart  DateTime?
  plannedEnd    DateTime?
  // 進捗率 0-100 (US-008)
  progress      Int              @default(0)
  assignee      Member?          @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeId    String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  reports       ProgressReport[]

  @@index([projectId])
  @@index([assigneeId])
}

/// 進捗報告 (US-007)。タスクの進捗率へ反映され(US-008)、遅延検出の根拠になる(US-009/010)。
model ProgressReport {
  id         String   @id @default(cuid())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId     String
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId   String
  progress   Int // 報告時点の進捗率 0-100
  comment    String?
  reportedAt DateTime @default(now())

  @@index([taskId])
  @@index([memberId])
}
